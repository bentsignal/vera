{
  "name": "@acme/db",
  "private": true,
  "type": "module",
  "exports": {
    "./api": {
      "types": "./src/_generated/api.d.ts",
      "default": "./src/_generated/api.js"
    },
    "./model": {
      "types": "./src/_generated/dataModel.d.ts"
    },
    "./models/types": "./src/ai/models/types.ts",
    "./models/helpers": "./src/ai/models/helpers.ts",
    "./models/language": "./src/ai/models/language.ts",
    "./models/image": "./src/ai/models/image.ts",
    "./models/presets": "./src/ai/models/presets.ts",
    "./models/voice": "./src/ai/models/voice.ts",
    "./models/embed": "./src/ai/models/embed.ts",
    "./tools": "./src/ai/tools/index.ts",
    "./tools/search": "./src/ai/tools/search/index.ts",
    "./subscription": "./src/user/subscription.ts",
    "./library-types": "./src/types/library.ts",
    "./agent/validators": "./src/agent/validators/index.ts",
    "./thread/shared": "./src/ai/thread/shared.ts",
    "./agent/ui": "./src/agent/ui/index.ts",
    "./agent/shared": "./src/agent/shared.ts",
    "./agent/deltas": "./src/agent/deltas/index.ts",
    "./agent/mapping": "./src/agent/mapping/index.ts",
    "./agent/types": "./lib/agent-client/types/index.ts",
    "./stream/error-codes": "./src/ai/stream/error_codes.ts",
    "./stream/notice-codes": "./src/ai/stream/notice_codes.ts"
  },
  "scripts": {
    "dev": "convex dev",
    "build": "convex deploy && pnpm run sync:products",
    "sync:products": "convex run billing/actions:syncProducts",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "fomat:fix": "prettier --write . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsgo --noEmit",
    "setup": "convex dev --until-success",
    "logs": "convex logs"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.97",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/provider-utils": "^4.0.23",
    "@clerk/nextjs": "^7.2.1",
    "@convex-dev/aggregate": "^0.2.1",
    "@convex-dev/migrations": "^0.3.3",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.3",
    "@convex-dev/sharded-counter": "^0.2.0",
    "@fal-ai/client": "catalog:",
    "@openrouter/ai-sdk-provider": "^2.5.1",
    "@polar-sh/sdk": "catalog:",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.6",
    "@upstash/redis": "^1.35.3",
    "ai": "catalog:",
    "convex": "catalog:",
    "convex-env": "^3.0.0",
    "convex-helpers": "catalog:",
    "effect": "4.0.0-beta.52",
    "react": "catalog:react19",
    "uploadthing": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
