{
  "name": "@acme/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env vite build",
    "dev": "portless",
    "dev:app": "pnpm with-env vite dev",
    "start": "node .output/server/index.mjs",
    "preview": "pnpm with-env vite preview",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsgo --noEmit",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "format:fix": "prettier --write . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "clean": "git clean -xdf node_modules .cache .tanstack .turbo .output",
    "with-env": "dotenv -e ./.env.local -e ./.env -e ../../.env --"
  },
  "dependencies": {
    "@acme/app-config": "workspace:*",
    "@acme/db": "workspace:*",
    "@acme/features": "workspace:*",
    "@acme/ui": "workspace:*",
    "@clerk/tanstack-react-start": "catalog:",
    "@clerk/themes": "catalog:",
    "@convex-dev/react-query": "catalog:",
    "@fal-ai/client": "catalog:",
    "@fal-ai/server-proxy": "catalog:",
    "@fontsource-variable/inter": "catalog:",
    "@fontsource-variable/roboto": "catalog:",
    "@fontsource-variable/roboto-mono": "catalog:",
    "@t3-oss/env-core": "catalog:",
    "@tanstack/devtools-vite": "catalog:",
    "@tanstack/react-devtools": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/react-router-ssr-query": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@uploadthing/react": "^7.3.2",
    "ai": "catalog:",
    "clsx": "catalog:",
    "convex": "catalog:",
    "fast-deep-equal": "catalog:",
    "katex": "^0.16.25",
    "lucide-react": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-markdown": "catalog:",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "rostra": "catalog:",
    "simple-icons": "^15.1.0",
    "sonner": "catalog:",
    "srvx": "catalog:",
    "tailwind-merge": "catalog:",
    "uploadthing": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@tailwindcss/typography": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "dotenv-cli": "catalog:",
    "eslint": "catalog:",
    "nitro": "catalog:",
    "prettier": "catalog:",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  },
  "portless": {
    "name": "www.vera",
    "script": "dev:app"
  }
}
